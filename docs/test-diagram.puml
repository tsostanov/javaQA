@startuml
title Test Architecture Diagram

left to right direction
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 35
skinparam ranksep 45
hide empty members

rectangle "lab2" {
  package "Unit Tests" {
    class AbstractMathModuleTest
    class CosModuleTest
    class SinModuleTest
    class SecModuleTest
    class CscModuleTest
    class CotModuleTest
    class LnModuleTest
    class LogModuleTest
    class FunctionSystemModuleTest
  }

  package "Integration Tests" {
    class SinIntegrationTest
    class SecIntegrationTest
    class CscIntegrationTest
    class CotIntegrationTest
    class LogIntegrationTest
    class FunctionSystemIntegrationTest
  }

  package "Bottom-Up / Real" {
    class TrigBottomUpIntegrationTest
    class LogBottomUpIntegrationTest
    class FunctionSystemRealIntegrationTest
  }

  package "Infrastructure Tests" {
    class CsvExporterTest
    class MainTest
  }

  package "Support" {
    class CsvTestData
    class MockitoMathModuleFactory
    class TrigIntegrationSupport
  }

  package "Production Classes" {
    class AbstractMathModule
    class CosModule
    class SinModule
    class SecModule
    class CscModule
    class CotModule
    class LnModule
    class LogModule
    class FunctionSystemModule
    class CsvExporter
    class Main
  }
}

AbstractMathModuleTest ..> AbstractMathModule
CsvExporterTest ..> CsvExporter
MainTest ..> Main

CosModuleTest ..> CosModule
SinModuleTest ..> SinModule
SecModuleTest ..> SecModule
CscModuleTest ..> CscModule
CotModuleTest ..> CotModule
LnModuleTest ..> LnModule
LogModuleTest ..> LogModule
FunctionSystemModuleTest ..> FunctionSystemModule

SinIntegrationTest ..> SinModule
SecIntegrationTest ..> SecModule
CscIntegrationTest ..> CscModule
CotIntegrationTest ..> CotModule
LogIntegrationTest ..> LogModule
FunctionSystemIntegrationTest ..> FunctionSystemModule

TrigBottomUpIntegrationTest ..> SinModule
TrigBottomUpIntegrationTest ..> SecModule
TrigBottomUpIntegrationTest ..> CscModule
TrigBottomUpIntegrationTest ..> CotModule
LogBottomUpIntegrationTest ..> LogModule
FunctionSystemRealIntegrationTest ..> FunctionSystemModule

CosModuleTest --> CsvTestData
LnModuleTest --> CsvTestData
LogModuleTest --> CsvTestData
FunctionSystemModuleTest --> CsvTestData
TrigIntegrationSupport --> CsvTestData

SinIntegrationTest --> MockitoMathModuleFactory
CotIntegrationTest --> MockitoMathModuleFactory
LogIntegrationTest --> MockitoMathModuleFactory
FunctionSystemIntegrationTest --> MockitoMathModuleFactory

SinIntegrationTest --> TrigIntegrationSupport
CotIntegrationTest --> TrigIntegrationSupport
TrigBottomUpIntegrationTest --> TrigIntegrationSupport

@enduml
